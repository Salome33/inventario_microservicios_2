            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Ana Barber\",\n  \"email\": \"ana.demo@barberia.com\",\n  \"password\": \"Secreto123\",\n  \"role\": \"CUSTOMER\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
